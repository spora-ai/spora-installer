{
    "name": "spora-ai/installer",
    "description": "Routes `spora-plugin` packages to `plugins/{$name}/` and `spora-frontend` packages to `public/dist/` when installed via Composer. Companion to spora-ai/spora-core.",
    "type": "composer-plugin",
    "license": "MIT",
    "version": "1.2.0",
    "require": {
        "php": "^8.4.1",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.7",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Spora\\Composer\\": "src/Composer/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Spora\\Composer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "class": "Spora\\Composer\\SporaPluginInstallerPlugin"
    }
}